import argparse
import os
from dataclasses import dataclass
import numpy as np
import pandas as pd
import cv2


# ---- Landmark IDs (Google 33-landmark pose; we use the subset you already export) ----
L_SHOULDER = 11
R_SHOULDER = 12
L_ELBOW = 13
R_ELBOW = 14
L_WRIST = 15
R_WRIST = 16
L_HIP = 23
R_HIP = 24
L_KNEE = 25
R_KNEE = 26


@dataclass
class ServeEvent:
    serve_id: int
    start_frame: int
    end_frame: int
    start_ms: int
    end_ms: int
    BR_frame: int
    TP_frame: int
    RLP_frame: int
    BI_frame: int
    BR_ms: int
    TP_ms: int
    RLP_ms: int
    BI_ms: int


def _pick_cols(df: pd.DataFrame, mode: str):
    """
    mode: raw | smooth
    Supports either:
      - compare csv: x_raw,y_raw,z_raw + x_s,y_s,z_s
      - normal csv:  x,y,z
    """
    cols = df.columns
    if mode == "smooth":
        if {"x_s", "y_s"}.issubset(cols):
            return "x_s", "y_s", "z_s"
    if mode == "raw":
        if {"x_raw", "y_raw"}.issubset(cols):
            return "x_raw", "y_raw", "z_raw"

    # fallback
    if {"x", "y"}.issubset(cols):
        return "x", "y", "z"
    # last fallback: if only raw exists
    if {"x_raw", "y_raw"}.issubset(cols):
        return "x_raw", "y_raw", "z_raw"
    raise ValueError("Cannot find usable coordinate columns in pose_csv.")


def load_pose_wide(pose_csv: str, detect_on: str):
    df = pd.read_csv(pose_csv, encoding="utf-8-sig")
    if "pose_id" not in df.columns:
        df["pose_id"] = 0

    xcol, ycol, zcol = _pick_cols(df, detect_on)
    vcol = "vis" if "vis" in df.columns else ("wvis" if "wvis" in df.columns else None)

    keep = ["frame", "ts_ms", "pose_id", "lm_id", xcol, ycol]
    if zcol in df.columns:
        keep.append(zcol)
    if vcol is not None:
        keep.append(vcol)

    df = df[keep].copy()
    df.rename(columns={xcol: "x", ycol: "y"}, inplace=True)
    if zcol in df.columns:
        df.rename(columns={zcol: "z"}, inplace=True)
    if vcol is not None:
        df.rename(columns={vcol: "vis"}, inplace=True)
    else:
        df["vis"] = 1.0

    # choose primary pose_id (the one most consistently visible)
    key_ids = [L_SHOULDER, R_SHOULDER, L_WRIST, R_WRIST, L_HIP, R_HIP]
    df_key = df[df["lm_id"].isin(key_ids)]
    score = df_key.groupby("pose_id")["vis"].mean().sort_values(ascending=False)
    pose_id = int(score.index[0]) if len(score) else 0
    df = df[df["pose_id"] == pose_id].copy()

    # pivot to wide by lm_id
    wide_x = df.pivot_table(index=["frame", "ts_ms"], columns="lm_id", values="x", aggfunc="mean")
    wide_y = df.pivot_table(index=["frame", "ts_ms"], columns="lm_id", values="y", aggfunc="mean")
    wide_v = df.pivot_table(index=["frame", "ts_ms"], columns="lm_id", values="vis", aggfunc="mean")

    # align & fill small gaps
    wide_x = wide_x.sort_index().interpolate(limit_direction="both")
    wide_y = wide_y.sort_index().interpolate(limit_direction="both")
    wide_v = wide_v.sort_index().fillna(0.0)

    idx = wide_x.index
    frames = idx.get_level_values(0).to_numpy()
    ts_ms = idx.get_level_values(1).to_numpy()

    return frames, ts_ms, wide_x, wide_y, wide_v


def _derivative(sig: np.ndarray, ts_ms: np.ndarray):
    t = ts_ms.astype(np.float64) / 1000.0
    dt = np.gradient(t)
    ds = np.gradient(sig)
    dt = np.where(dt == 0, 1e-6, dt)
    return ds / dt


def detect_serves(
    frames: np.ndarray,
    ts_ms: np.ndarray,
    X: pd.DataFrame,
    Y: pd.DataFrame,
    V: pd.DataFrame,
    hand: str,
    toss_up_thresh: float,
    min_gap_ms: int,
    min_len_ms: int,
    max_len_ms: int,
):
    # choose main/racket hand wrist
    if hand.lower() == "right":
        racket_wrist = R_WRIST
        toss_wrist = L_WRIST
        racket_elbow = R_ELBOW
        racket_shoulder = R_SHOULDER
        toss_shoulder = L_SHOULDER
    else:
        racket_wrist = L_WRIST
        toss_wrist = R_WRIST
        racket_elbow = L_ELBOW
        racket_shoulder = L_SHOULDER
        toss_shoulder = R_SHOULDER

    needed = [toss_wrist, toss_shoulder, racket_wrist, racket_elbow, racket_shoulder, L_HIP, R_HIP]
    for k in needed:
        if k not in Y.columns:
            raise ValueError(f"Missing landmark id {k} in pose csv. Your csv must include it.")

    # signals
    toss_y = Y[toss_wrist].to_numpy()
    toss_sh_y = Y[toss_shoulder].to_numpy()
    racket_y = Y[racket_wrist].to_numpy()
    racket_sh_y = Y[racket_shoulder].to_numpy()
    racket_el_y = Y[racket_elbow].to_numpy()

    toss_vy = _derivative(toss_y, ts_ms)
    racket_speed = np.sqrt(_derivative(X[racket_wrist].to_numpy(), ts_ms) ** 2 + _derivative(racket_y, ts_ms) ** 2)

    # "toss arm up" boolean (y smaller => higher on screen)
    toss_up = (toss_sh_y - toss_y) > toss_up_thresh

    # toss start candidates: rising + up
    rising = toss_vy < -0.15  # y decreasing (upwards)
    toss_start = np.where(toss_up & rising)[0]

    # de-duplicate by min_gap_ms
    serve_candidates = []
    last_ms = -10**18
    for i in toss_start:
        if ts_ms[i] - last_ms >= min_gap_ms:
            serve_candidates.append(i)
            last_ms = ts_ms[i]

    events: list[ServeEvent] = []
    sid = 0

    def _clip_idx(i0, i1):
        i0 = max(0, int(i0))
        i1 = min(len(frames) - 1, int(i1))
        return i0, i1

    for i0 in serve_candidates:
        # ---- BR (ball release proxy): toss wrist peak (vy crosses from up->down) while arm is up ----
        w0, w1 = _clip_idx(i0, i0 + 180)  # ~3s at 60fps; independent of fps because we also use ms
        br = None
        for i in range(w0 + 1, w1):
            if toss_up[i] and toss_vy[i - 1] < 0 and toss_vy[i] > 0:
                br = i
                break
        if br is None:
            # fallback: highest toss wrist (min y) within window
            br = int(w0 + np.argmin(toss_y[w0:w1 + 1]))

        # ---- TP (trophy / racquet high point): racket wrist highest after BR, while elbow is high ----
        tp_w0, tp_w1 = _clip_idx(br, br + 150)  # ~2.5s-ish window
        elbow_high = (racket_sh_y - racket_el_y) > 0.02
        cand = np.where(elbow_high[tp_w0:tp_w1 + 1])[0]
        if len(cand) < 5:
            continue
        # within valid elbow_high frames, pick min racket_y
        sub = racket_y[tp_w0:tp_w1 + 1].copy()
        mask = np.ones_like(sub, dtype=bool)
        mask[cand] = False
        sub[mask] = 1.0  # push invalid to bottom
        tp = int(tp_w0 + np.argmin(sub))

        # ---- RLP (racquet low point): racket wrist lowest (max y) after TP ----
        rlp_w0, rlp_w1 = _clip_idx(tp + 1, tp + 220)  # ~3.5s window
        rlp = int(rlp_w0 + np.argmax(racket_y[rlp_w0:rlp_w1 + 1]))

        # ---- BI (ball impact proxy): near max racket wrist speed after RLP ----
        bi_w0, bi_w1 = _clip_idx(rlp + 1, rlp + 120)  # ~2s window
        bi = int(bi_w0 + np.argmax(racket_speed[bi_w0:bi_w1 + 1]))

        # serve segment boundaries
        start_ms = int(ts_ms[br] - 700)  # include toss start
        end_ms = int(ts_ms[bi] + 700)    # include follow-through
        # map back to frame range
        start_idx = int(np.searchsorted(ts_ms, start_ms, side="left"))
        end_idx = int(np.searchsorted(ts_ms, end_ms, side="right") - 1)
        start_idx, end_idx = _clip_idx(start_idx, end_idx)

        seg_len = int(ts_ms[end_idx] - ts_ms[start_idx])
        if seg_len < min_len_ms or seg_len > max_len_ms:
            continue

        # extra sanity: racket hand should be above shoulder at TP (rough)
        if (racket_sh_y[tp] - racket_y[tp]) < 0.03:
            continue

        sid += 1
        events.append(
            ServeEvent(
                serve_id=sid,
                start_frame=int(frames[start_idx]),
                end_frame=int(frames[end_idx]),
                start_ms=int(ts_ms[start_idx]),
                end_ms=int(ts_ms[end_idx]),
                BR_frame=int(frames[br]),
                TP_frame=int(frames[tp]),
                RLP_frame=int(frames[rlp]),
                BI_frame=int(frames[bi]),
                BR_ms=int(ts_ms[br]),
                TP_ms=int(ts_ms[tp]),
                RLP_ms=int(ts_ms[rlp]),
                BI_ms=int(ts_ms[bi]),
            )
        )

    return events


def write_segments_csv(events: list[ServeEvent], out_csv: str):
    rows = []
    for e in events:
        rows.append({
            "serve_id": e.serve_id,
            "start_frame": e.start_frame, "end_frame": e.end_frame,
            "start_ms": e.start_ms, "end_ms": e.end_ms,
            "BR_frame": e.BR_frame, "TP_frame": e.TP_frame, "RLP_frame": e.RLP_frame, "BI_frame": e.BI_frame,
            "BR_ms": e.BR_ms, "TP_ms": e.TP_ms, "RLP_ms": e.RLP_ms, "BI_ms": e.BI_ms,
        })
    pd.DataFrame(rows).to_csv(out_csv, index=False, encoding="utf-8-sig")


def render_vis(video_path: str, pose_csv: str, events: list[ServeEvent], out_mp4: str, hand: str, draw_on: str):
    # load again for drawing columns (may differ from detect_on)
    df = pd.read_csv(pose_csv, encoding="utf-8-sig")
    if "pose_id" not in df.columns:
        df["pose_id"] = 0
    xcol, ycol, _ = _pick_cols(df, draw_on)
    vcol = "vis" if "vis" in df.columns else ("wvis" if "wvis" in df.columns else None)

    # pick pose_id same way
    key_ids = [L_SHOULDER, R_SHOULDER, L_WRIST, R_WRIST, L_HIP, R_HIP]
    df_key = df[df["lm_id"].isin(key_ids)]
    score = df_key.groupby("pose_id")[vcol].mean().sort_values(ascending=False) if vcol else df_key.groupby("pose_id").size()
    pose_id = int(score.index[0]) if len(score) else 0
    df = df[df["pose_id"] == pose_id].copy()

    df = df[["frame", "lm_id", xcol, ycol]].copy()
    df.rename(columns={xcol: "x", ycol: "y"}, inplace=True)

    # quick dict: frame -> {lm_id: (x,y)}
    grouped = df.groupby("frame")
    frame_map = {}
    for f, g in grouped:
        frame_map[int(f)] = dict(zip(g["lm_id"].astype(int).tolist(), zip(g["x"].tolist(), g["y"].tolist())))

    cap = cv2.VideoCapture(video_path)
    if not cap.isOpened():
        raise RuntimeError(f"Cannot open video: {video_path}")

    w = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
    h = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
    fps = cap.get(cv2.CAP_PROP_FPS)
    if fps <= 0:
        fps = 30.0

    fourcc = cv2.VideoWriter_fourcc(*"mp4v")
    os.makedirs(os.path.dirname(out_mp4), exist_ok=True)
    writer = cv2.VideoWriter(out_mp4, fourcc, fps, (w, h))

    # event lookup by frame
    # for each frame, find which serve it belongs to (if any)
    ev_by_frame = {}
    for e in events:
        for f in range(e.start_frame, e.end_frame + 1):
            ev_by_frame[f] = e

    if hand.lower() == "right":
        racket_wrist = R_WRIST
        toss_wrist = L_WRIST
    else:
        racket_wrist = L_WRIST
        toss_wrist = R_WRIST

    def phase_label(e: ServeEvent, f: int):
        if f < e.BR_frame: return "PRE"
        if f < e.TP_frame: return "BR->TP"
        if f < e.RLP_frame: return "TP->RLP"
        if f < e.BI_frame: return "RLP->BI"
        return "FOLLOW"

    fidx = 0
    while True:
        ok, frame = cap.read()
        if not ok:
            break

        e = ev_by_frame.get(fidx, None)
        if e is not None:
            # border
            cv2.rectangle(frame, (8, 8), (w - 8, h - 8), (0, 255, 255), 4)
            txt = f"Serve #{e.serve_id}  {phase_label(e, fidx)}"
            cv2.putText(frame, txt, (20, 50), cv2.FONT_HERSHEY_SIMPLEX, 1.2, (0, 255, 255), 3)

            # mark key events
            for name, ff in [("BR", e.BR_frame), ("TP", e.TP_frame), ("RLP", e.RLP_frame), ("BI", e.BI_frame)]:
                if abs(fidx - ff) <= 1:
                    cv2.putText(frame, f"{name}!", (20, 95), cv2.FONT_HERSHEY_SIMPLEX, 1.2, (0, 0, 255), 3)

        pts = frame_map.get(fidx, None)
        if pts:
            for lm, color in [(toss_wrist, (255, 0, 0)), (racket_wrist, (0, 255, 0))]:
                if lm in pts:
                    x, y = pts[lm]
                    cx, cy = int(x * w), int(y * h)
                    cv2.circle(frame, (cx, cy), 6, color, -1)

        writer.write(frame)
        fidx += 1

    cap.release()
    writer.release()


def cut_clips(video_path: str, events: list[ServeEvent], out_dir: str):
    os.makedirs(out_dir, exist_ok=True)
    cap = cv2.VideoCapture(video_path)
    if not cap.isOpened():
        raise RuntimeError(f"Cannot open video: {video_path}")

    w = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
    h = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
    fps = cap.get(cv2.CAP_PROP_FPS)
    if fps <= 0:
        fps = 30.0
    fourcc = cv2.VideoWriter_fourcc(*"mp4v")

    for e in events:
        out_path = os.path.join(out_dir, f"serve_{e.serve_id:03d}.mp4")
        writer = cv2.VideoWriter(out_path, fourcc, fps, (w, h))

        cap.set(cv2.CAP_PROP_POS_FRAMES, e.start_frame)
        for _ in range(e.start_frame, e.end_frame + 1):
            ok, frame = cap.read()
            if not ok:
                break
            writer.write(frame)
        writer.release()

    cap.release()


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--video", required=True)
    ap.add_argument("--pose_csv", required=True)
    ap.add_argument("--out_dir", required=True)
    ap.add_argument("--hand", default="right", choices=["right", "left"])
    ap.add_argument("--detect_on", default="raw", choices=["raw", "smooth"])
    ap.add_argument("--draw_on", default="smooth", choices=["raw", "smooth"])
    ap.add_argument("--toss_up_thresh", type=float, default=0.06)
    ap.add_argument("--min_gap_ms", type=int, default=1200)
    ap.add_argument("--min_len_ms", type=int, default=900)
    ap.add_argument("--max_len_ms", type=int, default=4500)
    ap.add_argument("--make_clips", type=int, default=1)
    args = ap.parse_args()

    os.makedirs(args.out_dir, exist_ok=True)
    segments_csv = os.path.join(args.out_dir, "serve_segments.csv")
    vis_mp4 = os.path.join(args.out_dir, "serve_vis.mp4")
    clips_dir = os.path.join(args.out_dir, "clips")

    frames, ts_ms, X, Y, V = load_pose_wide(args.pose_csv, args.detect_on)
    events = detect_serves(
        frames, ts_ms, X, Y, V,
        hand=args.hand,
        toss_up_thresh=args.toss_up_thresh,
        min_gap_ms=args.min_gap_ms,
        min_len_ms=args.min_len_ms,
        max_len_ms=args.max_len_ms,
    )

    print(f"[OK] Detected serves: {len(events)}")
    write_segments_csv(events, segments_csv)
    print(f"[OK] Saved segments csv: {segments_csv}")

    render_vis(args.video, args.pose_csv, events, vis_mp4, hand=args.hand, draw_on=args.draw_on)
    print(f"[OK] Saved visualization video: {vis_mp4}")

    if args.make_clips == 1:
        cut_clips(args.video, events, clips_dir)
        print(f"[OK] Saved serve clips to: {clips_dir}")


if __name__ == "__main__":
    main()
